                </div>
            </div>
            <div class="p-5 border-t bg-gray-50 text-right">
                <button onclick="toggleModal('devModal')" class="bg-gray-800 text-white px-6 py-2 rounded-lg hover:bg-gray-900 transition-colors">ปิดหน้าต่าง</button>
            </div>
        </div>
    </div>

    <script>
        // --- 1. การตั้งค่า Backend URL (ใส่ URL ของคุณเรียบร้อยแล้ว) ---
        const GAS_URL = 'https://script.google.com/macros/s/AKfycbwhyybGIe0-qtSSHxbSBopkwFrbpD24mCWt_1ocvOW_db4vIw6ckX92uLnU2iXhb-4a/exec';

        // --- 2. ฟังก์ชันคำนวณระยะเวลาเดินทางอัตโนมัติ ---
        const startInput = document.getElementById('startDate');
        const endInput = document.getElementById('endDate');
        const durationInput = document.getElementById('duration');

        function calculateDuration() {
            if (startInput.value && endInput.value) {
                const start = new Date(startInput.value);
                const end = new Date(endInput.value);
                
                // ตรวจสอบว่าวันกลับ ต้องไม่ก่อนวันเริ่ม
                if (end < start) {
                    endInput.value = startInput.value;
                } else {
                    const diffTime = Math.abs(end - start);
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                    // บวก 1 เพื่อรวมวันแรกด้วย (เช่น ไป 1 กลับ 2 = 2 วัน)
                    durationInput.value = diffDays + 1;
                }
            }
        }
        startInput.addEventListener('change', calculateDuration);
        endInput.addEventListener('change', calculateDuration);

        // --- 3. ระบบแสดงตัวอย่างรูปภาพก่อนอัปโหลด ---
        const imageInput = document.getElementById('images');
        const imagePreview = document.getElementById('imagePreview');
        let selectedFiles = []; // เก็บไฟล์ที่ผู้ใช้เลือก

        imageInput.addEventListener('change', function(e) {
            const files = Array.from(e.target.files);
            
            files.forEach(file => {
                // เก็บไฟล์ลง Array เพื่อรอส่ง
                selectedFiles.push(file);

                // สร้างรูปตัวอย่าง
                const reader = new FileReader();
                reader.onload = function(e) {
                    const div = document.createElement('div');
                    div.className = 'relative w-20 h-20 rounded-lg overflow-hidden border border-gray-200 shadow-sm group';
                    div.innerHTML = `
                        <img src="${e.target.result}" class="w-full h-full object-cover">
                        <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity cursor-pointer text-white" onclick="removeImage(this, '${file.name}')">
                            <i class="fa-solid fa-trash"></i>
                        </div>
                    `;
                    imagePreview.appendChild(div);
                }
                reader.readAsDataURL(file);
            });
            // เคลียร์ input เผื่อเลือกไฟล์เดิมซ้ำ
            imageInput.value = '';
        });

        // ลบรูปภาพออกจากตัวเลือก
        function removeImage(btnElement, fileName) {
            // ลบ UI
            btnElement.parentElement.remove();
            // ลบจาก Array
            selectedFiles = selectedFiles.filter(f => f.name !== fileName);
        }

        // แปลงและลดขนาดไฟล์ (Compress) เป็น Base64 สำหรับส่งไป GAS เพื่อลดขนาดข้อมูล ป้องกัน Error
        const compressImage = (file, maxWidth = 1024, maxHeight = 1024, quality = 0.7) => new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = (event) => {
                const img = new Image();
                img.src = event.target.result;
                img.onload = () => {
                    let width = img.width;
                    let height = img.height;
                    if (width > height) {
                        if (width > maxWidth) { height = Math.round((height * maxWidth) / width); width = maxWidth; }
                    } else {
                        if (height > maxHeight) { width = Math.round((width * maxHeight) / height); height = maxHeight; }
                    }
                    const canvas = document.createElement('canvas');
                    canvas.width = width; canvas.height = height;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);
                    resolve({
                        filename: file.name.replace(/\.[^/.]+$/, "") + ".jpg", // เปลี่ยนเป็น jpg เพื่อลดขนาด
                        base64: canvas.toDataURL('image/jpeg', quality)
                    });
                };
                img.onerror = error => reject(error);
            };
            reader.onerror = error => reject(error);
        });

        // --- 4. จัดการตอนกดปุ่มส่งข้อมูล ---
        const form = document.getElementById('travelForm');
        const submitBtn = document.getElementById('submitBtn');

        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            // เปลี่ยนหน้าตาปุ่มเป็นกำลังโหลด
            const originalBtnText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="loader"></span> กำลังบันทึกข้อมูลและอัปโหลดรูป...';
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-75', 'cursor-not-allowed');

            try {
                // รวบรวมข้อมูล Checkbox (ประเภททริป)
                const tripTypes = [];
                document.querySelectorAll('input[name="tripType"]:checked').forEach(cb => {
                    tripTypes.push(cb.value);
                });

                // รวบรวมรูปภาพและลดขนาดเป็น Base64
                const imagesBase64 = [];
                for (let file of selectedFiles) {
                    const b64 = await compressImage(file);
                    imagesBase64.push(b64);
                }

                // สร้าง Object ข้อมูลทั้งหมดที่จะส่งไป Backend
                const payload = {
                    destination: document.getElementById('destination').value,
                    tripTypes: tripTypes,
                    startDate: document.getElementById('startDate').value,
                    endDate: document.getElementById('endDate').value,
                    duration: document.getElementById('duration').value,
                    travelers: document.getElementById('travelers').value,
                    budget: document.getElementById('budget').value,
                    notes: document.getElementById('notes').value,
                    images: imagesBase64
                };

                // ทำการส่งข้อมูลไปยัง Google Apps Script
                await fetch(GAS_URL, {
                    method: 'POST',
                    mode: 'no-cors', // สำคัญ: เพื่อไม่ให้บราวเซอร์บล็อกการส่งข้อมูลข้ามโดเมน
                    headers: {
                        'Content-Type': 'text/plain;charset=utf-8', // เปลี่ยนเป็น text/plain เพื่อป้องกันบราวเซอร์บางชนิดตัดข้อมูลบอดี้ทิ้งเมื่อใช้ร่วมกับ no-cors
                    },
                    body: JSON.stringify(payload)
                });
                
                // แสดงข้อความสำเร็จ
                showNotification('บันทึกสำเร็จ!', 'ข้อมูลและรูปภาพถูกส่งไปยังระบบเรียบร้อยแล้ว');
                
                // ล้างฟอร์ม
                form.reset();
                imagePreview.innerHTML = '';
                selectedFiles = [];

            } catch (error) {
                showNotification('ข้อผิดพลาด', 'เกิดข้อผิดพลาดในการเชื่อมต่อ: ' + error.message, true);
            } finally {
                // คืนค่าปุ่มกลับมาเหมือนเดิม
                submitBtn.innerHTML = originalBtnText;
                submitBtn.disabled = false;
                submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
            }
        });

        // --- 5. UI Helpers และระบบแจ้งเตือนแบบ Pop-up (แทนที่ Alert) ---
        function showNotification(title, message, isError = false) {
            const alertBox = document.getElementById('alertMsg');
            const iconBg = document.getElementById('alertIconBg');
            const icon = document.getElementById('alertIcon');
            
            document.getElementById('alertTitle').innerText = title;
            document.getElementById('alertDesc').innerText = message;
            
            // เปลี่ยนสไตล์ตามประเภท Error / Success
            if (isError) {
                alertBox.className = 'fixed bottom-5 right-5 transform translate-y-20 opacity-0 transition-all duration-300 bg-white border-l-4 border-red-500 p-4 rounded shadow-xl flex items-center gap-3 z-50';
                iconBg.className = 'rounded-full bg-red-100 p-2';
                icon.className = 'fa-solid fa-xmark text-red-600';
            } else {
                alertBox.className = 'fixed bottom-5 right-5 transform translate-y-20 opacity-0 transition-all duration-300 bg-white border-l-4 border-emerald-500 p-4 rounded shadow-xl flex items-center gap-3 z-50';
                iconBg.className = 'rounded-full bg-emerald-100 p-2';
                icon.className = 'fa-solid fa-check text-emerald-600';
            }

            alertBox.classList.remove('translate-y-20', 'opacity-0');
            setTimeout(() => {
                alertBox.classList.add('translate-y-20', 'opacity-0');
            }, 4000);
        }

        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            const content = document.getElementById(modalID + 'Content');
            if (modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                setTimeout(() => {
                    modal.classList.remove('opacity-0');
                    content.classList.remove('scale-95');
                }, 10);
            } else {
                modal.classList.add('opacity-0');
                content.classList.add('scale-95');
                setTimeout(() => {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                }, 300);
            }
        }

        function copyCode() {
            const code = document.getElementById('gasCode').innerText;
            
            // สร้าง Textarea ชั่วคราวขึ้นมาเพื่อคัดลอก (ใช้ document.execCommand แทน navigator.clipboard เพื่อป้องกันการถูกบล็อกใน iFrame)
            const textArea = document.createElement("textarea");
            textArea.value = code;
            
            // ซ่อน textarea ไม่ให้มองเห็นบนหน้าเว็บ
            textArea.style.position = "fixed";
            textArea.style.left = "-9999px";
            document.body.appendChild(textArea);
            
            textArea.select();
            
            try {
                document.execCommand('copy');
                showNotification('คัดลอกสำเร็จ!', 'นำโค้ดไปวางใน Apps Script ได้เลย');
            } catch (err) {
                showNotification('เกิดข้อผิดพลาด', 'ไม่สามารถคัดลอกข้อความได้ โปรดคัดลอกด้วยตนเอง', true);
            }
            
            // ลบ textarea ทิ้งเมื่อใช้งานเสร็จ
            document.body.removeChild(textArea);
        }

        // --- 6. ระบบสลับหน้าเว็บ (Tab Switching) และ Dashboard ---
        function switchTab(tab) {
            const formView = document.getElementById('view-form');
            const dashView = document.getElementById('view-dashboard');
            const tabFormBtn = document.getElementById('tab-form');
            const tabDashBtn = document.getElementById('tab-dashboard');

            if (tab === 'form') {
                formView.classList.remove('hidden');
                dashView.classList.add('hidden');
                
                tabFormBtn.className = 'bg-primary text-white px-6 py-2 rounded-lg font-semibold shadow transition-all';
                tabDashBtn.className = 'bg-white text-gray-600 px-6 py-2 rounded-lg font-semibold shadow hover:bg-gray-50 transition-all';
            } else {
                formView.classList.add('hidden');
                dashView.classList.remove('hidden');
                
                tabFormBtn.className = 'bg-white text-gray-600 px-6 py-2 rounded-lg font-semibold shadow hover:bg-gray-50 transition-all';
                tabDashBtn.className = 'bg-primary text-white px-6 py-2 rounded-lg font-semibold shadow transition-all';
                
                loadDashboardData();
            }
        }

        async function loadDashboardData() {
            if (!GAS_URL) {
                showNotification('ไม่สามารถโหลดข้อมูลได้', 'โปรดใส่ URL ของ Apps Script ก่อน', true);
                return;
            }

            const loader = document.getElementById('dashboard-loader');
            const table = document.getElementById('dashboard-table');
            const tbody = document.getElementById('dashboard-tbody');
            const emptyState = document.getElementById('dashboard-empty');
            
            // รีเซ็ต UI เป็นสถานะกำลังโหลด
            loader.classList.remove('hidden');
            table.classList.add('hidden');
            emptyState.classList.add('hidden');

            try {
                // ดึงข้อมูลผ่าน GET request
                // หมายเหตุ: กรณีดึงข้อมูล ห้ามใช้ mode: 'no-cors' เพื่อให้สามารถอ่านบอดี้แบบ JSON ได้
                const response = await fetch(GAS_URL);
                const result = await response.json();

                if (result.status === 'success' && result.data.length > 0) {
                    const data = result.data;
                    
                    // ตัวแปรเก็บยอดสรุป
                    let totalBudget = 0;
                    let totalDays = 0;
                    
                    tbody.innerHTML = ''; // เคลียร์เนื้อหาตารางเดิม
                    
                    // เรียงข้อมูลจากใหม่ไปเก่า (อิงจากแถวล่าสุด)
                    const reversedData = [...data].reverse();

                    reversedData.forEach(trip => {
                        // บวกยอด
                        totalBudget += Number(trip.budget) || 0;
                        totalDays += Number(trip.duration) || 0;

                        // แปลงฟอร์แมตวันที่
                        let dateStr = '-';
                        if(trip.startDate) {
                             dateStr = new Date(trip.startDate).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' });
                        }
                        
                        // มีรูปภาพหรือไม่
                        const hasImage = trip.images && trip.images.trim() !== '' ? '<i class="fa-solid fa-image text-emerald-500 mr-2" title="มีรูปภาพ"></i>' : '';
                        
                        // แทรกแถวตาราง
                        const tr = document.createElement('tr');
                        tr.className = 'border-b border-gray-100 hover:bg-gray-50 transition-colors';
                        tr.innerHTML = `
                            <td class="py-4 font-medium text-gray-800 whitespace-nowrap">${hasImage}${trip.destination || '-'}</td>
                            <td class="py-4 whitespace-nowrap">${dateStr}</td>
                            <td class="py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">
                                    ${trip.tripTypes || 'ทั่วไป'}
                                </span>
                            </td>
                            <td class="py-4 text-center">${trip.travelers ? trip.travelers + ' คน' : '-'}</td>
                            <td class="py-4 text-right font-medium text-gray-800">${trip.budget ? Number(trip.budget).toLocaleString() + ' ฿' : '-'}</td>
                        `;
                        tbody.appendChild(tr);
                    });

                    // อัปเดตตัวเลขหน้าการ์ด
                    document.getElementById('dash-total-trips').innerText = data.length.toLocaleString();
                    document.getElementById('dash-total-budget').innerText = totalBudget.toLocaleString() + ' ฿';
                    document.getElementById('dash-total-days').innerText = totalDays.toLocaleString();

                    loader.classList.add('hidden');
                    table.classList.remove('hidden');
                } else {
                    // กรณีระบบปกติแต่ยังไม่มีแถวข้อมูล
                    document.getElementById('dash-total-trips').innerText = '0';
                    document.getElementById('dash-total-budget').innerText = '0 ฿';
                    document.getElementById('dash-total-days').innerText = '0';
                    
                    loader.classList.add('hidden');
                    emptyState.classList.remove('hidden');
                }
            } catch (error) {
                console.error("Error fetching data:", error);
                loader.classList.add('hidden');
                emptyState.classList.remove('hidden');
                emptyState.innerHTML = `<i class="fa-solid fa-triangle-exclamation text-4xl mb-3 text-red-300"></i><p class="text-red-500">เกิดข้อผิดพลาดในการโหลดข้อมูล<br><span class="text-xs text-gray-400">โปรดตรวจสอบว่าได้อัปเดตโค้ด Apps Script และ Deploy เป็นเวอร์ชันใหม่ (New Version) แล้ว</span></p>`;
            }
        }
    </script>
</body>

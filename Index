<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Travel Log - ระบบบันทึกการท่องเที่ยว</title>
    <!-- Tailwind CSS สำหรับตกแต่ง -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome สำหรับไอคอน -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Google Fonts (Prompt) -->
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Prompt', 'sans-serif'],
                    },
                    colors: {
                        primary: '#059669', // Emerald 600
                        secondary: '#10b981', // Emerald 500
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #f3f4f6; }
        /* ซ่อน Scrollbar แต่ยังเลื่อนได้ */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        .loader {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #059669;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
            display: inline-block;
            vertical-align: middle;
            margin-right: 8px;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body class="text-gray-800 antialiased min-h-screen flex flex-col items-center py-10 px-4">

    <!-- Header Section -->
    <div class="w-full max-w-3xl flex justify-between items-end mb-6">
        <div>
            <h1 class="text-4xl font-bold text-primary flex items-center gap-3">
                <i class="fa-solid fa-plane-departure"></i> Travel Log
            </h1>
            <p class="text-gray-500 mt-2">บันทึกความทรงจำและข้อมูลทริปการเดินทางของคุณ</p>
        </div>
        <button onclick="toggleModal('devModal')" class="text-sm bg-gray-800 hover:bg-gray-900 text-white py-2 px-4 rounded-lg shadow transition-colors flex items-center gap-2">
            <i class="fa-solid fa-code"></i> ตรวจสอบโค้ด Backend
        </button>
    </div>

    <!-- Navigation Tabs -->
    <div class="w-full max-w-3xl flex gap-4 mb-6">
        <button onclick="switchTab('form')" id="tab-form" class="bg-primary text-white px-6 py-2 rounded-lg font-semibold shadow transition-all">
            <i class="fa-solid fa-pen-to-square mr-2"></i> บันทึกทริป
        </button>
        <button onclick="switchTab('dashboard')" id="tab-dashboard" class="bg-white text-gray-600 px-6 py-2 rounded-lg font-semibold shadow hover:bg-gray-50 transition-all">
            <i class="fa-solid fa-chart-pie mr-2"></i> แดชบอร์ด
        </button>
    </div>

    <!-- Main Form Container -->
    <div id="view-form" class="w-full max-w-3xl bg-white rounded-2xl shadow-xl overflow-hidden transition-all">
        <div class="bg-emerald-50 border-b border-emerald-100 p-6">
            <h2 class="text-xl font-semibold text-emerald-800">กรอกข้อมูลทริปใหม่</h2>
        </div>
        
        <form id="travelForm" class="p-6 md:p-8 space-y-6">
            <!-- 1. จุดหมาย -->
            <div>
                <label for="destination" class="block text-sm font-medium text-gray-700 mb-1">จุดหมายปลายทาง <span class="text-red-500">*</span></label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fa-solid fa-location-dot text-gray-400"></i>
                    </div>
                    <input type="text" id="destination" name="destination" required placeholder="เช่น น้ำตกสามหลั่น, ภูกระดึง" 
                        class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-shadow">
                </div>
            </div>

            <!-- 2. ประเภททริป -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">ประเภททริป (เลือกได้มากกว่า 1)</label>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                    <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-emerald-50 transition-colors has-[:checked]:bg-emerald-100 has-[:checked]:border-primary">
                        <input type="checkbox" name="tripType" value="แคมป์ปิ้ง" class="w-4 h-4 text-primary rounded focus:ring-primary accent-primary">
                        <span class="ml-2 text-sm">🏕️ แคมป์ปิ้ง</span>
                    </label>
                    <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-emerald-50 transition-colors has-[:checked]:bg-emerald-100 has-[:checked]:border-primary">
                        <input type="checkbox" name="tripType" value="เดินป่า" class="w-4 h-4 text-primary rounded focus:ring-primary accent-primary">
                        <span class="ml-2 text-sm">🥾 เดินป่า</span>
                    </label>
                    <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-emerald-50 transition-colors has-[:checked]:bg-emerald-100 has-[:checked]:border-primary">
                        <input type="checkbox" name="tripType" value="เล่นน้ำ" class="w-4 h-4 text-primary rounded focus:ring-primary accent-primary">
                        <span class="ml-2 text-sm">🏊 เล่นน้ำ</span>
                    </label>
                    <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-emerald-50 transition-colors has-[:checked]:bg-emerald-100 has-[:checked]:border-primary">
                        <input type="checkbox" name="tripType" value="พักผ่อน" class="w-4 h-4 text-primary rounded focus:ring-primary accent-primary">
                        <span class="ml-2 text-sm">☕ พักผ่อนชิลๆ</span>
                    </label>
                    <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-emerald-50 transition-colors has-[:checked]:bg-emerald-100 has-[:checked]:border-primary">
                        <input type="checkbox" name="tripType" value="ภูเขา" class="w-4 h-4 text-primary rounded focus:ring-primary accent-primary">
                        <span class="ml-2 text-sm">⛰️ ขึ้นเขา</span>
                    </label>
                    <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-emerald-50 transition-colors has-[:checked]:bg-emerald-100 has-[:checked]:border-primary">
                        <input type="checkbox" name="tripType" value="ทะเล" class="w-4 h-4 text-primary rounded focus:ring-primary accent-primary">
                        <span class="ml-2 text-sm">🌊 ทะเล</span>
                    </label>
                </div>
            </div>

            <!-- 3-5. วันที่ และ ระยะเวลา -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label for="startDate" class="block text-sm font-medium text-gray-700 mb-1">วันเริ่มเดินทาง <span class="text-red-500">*</span></label>
                    <input type="date" id="startDate" name="startDate" required 
                        class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>
                <div>
                    <label for="endDate" class="block text-sm font-medium text-gray-700 mb-1">วันกลับเดินทาง <span class="text-red-500">*</span></label>
                    <input type="date" id="endDate" name="endDate" required 
                        class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>
                <div>
                    <label for="duration" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลา (วัน)</label>
                    <div class="relative">
                        <input type="number" id="duration" name="duration" readonly placeholder="คำนวณอัตโนมัติ"
                            class="w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-gray-500 cursor-not-allowed">
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <span class="text-gray-400 text-sm">วัน</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 6-7. จำนวนคน และ งบประมาณ -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="travelers" class="block text-sm font-medium text-gray-700 mb-1">จำนวนผู้เดินทาง (คน) <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-user-group text-gray-400"></i>
                        </div>
                        <input type="number" id="travelers" name="travelers" min="1" required placeholder="เช่น 2"
                            class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    </div>
                </div>
                <div>
                    <label for="budget" class="block text-sm font-medium text-gray-700 mb-1">งบประมาณรวม (บาท)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-baht-sign text-gray-400"></i>
                        </div>
                        <input type="number" id="budget" name="budget" min="0" placeholder="เช่น 5000"
                            class="pl-10 w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    </div>
                </div>
            </div>

            <!-- 8. รูปภาพ -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">อัปโหลดรูปภาพ (บันทึกลง Google Drive)</label>
                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-xl hover:border-primary transition-colors bg-gray-50 relative">
                    <div class="space-y-1 text-center">
                        <i class="fa-regular fa-images text-4xl text-gray-400 mb-3"></i>
                        <div class="flex text-sm text-gray-600 justify-center">
                            <label for="images" class="relative cursor-pointer bg-white rounded-md font-medium text-primary hover:text-emerald-500 focus-within:outline-none px-2 py-1 shadow-sm border">
                                <span>เลือกรูปภาพ</span>
                                <input id="images" name="images" type="file" class="sr-only" multiple accept="image/*">
                            </label>
                            <p class="pl-2 py-1">หรือลากไฟล์มาวางที่นี่</p>
                        </div>
                        <p class="text-xs text-gray-500">PNG, JPG, GIF อัปโหลดได้หลายไฟล์</p>
                    </div>
                </div>
                <!-- Image Preview Area -->
                <div id="imagePreview" class="flex flex-wrap gap-3 mt-4 empty:hidden"></div>
            </div>

            <!-- 9. หมายเหตุ -->
            <div>
                <label for="notes" class="block text-sm font-medium text-gray-700 mb-1">หมายเหตุ / ความประทับใจ</label>
                <textarea id="notes" name="notes" rows="3" placeholder="เขียนบันทึกความทรงจำ รีวิวที่พัก หรือร้านอาหาร..."
                    class="w-full rounded-lg border border-gray-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"></textarea>
            </div>

            <!-- Submit Button -->
            <div class="pt-4 border-t border-gray-100">
                <button type="submit" id="submitBtn" class="w-full bg-primary hover:bg-emerald-700 text-white font-bold py-4 px-8 rounded-xl shadow-lg hover:shadow-xl transition-all flex items-center justify-center gap-2 text-lg">
                    <i class="fa-solid fa-cloud-arrow-up"></i> บันทึกข้อมูลทริป
                </button>
            </div>
        </form>
    </div>

    <!-- Dashboard Container -->
    <div id="view-dashboard" class="hidden w-full max-w-4xl space-y-6">
        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white p-6 rounded-2xl shadow-lg border-l-4 border-emerald-500 flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm font-medium">จำนวนทริปทั้งหมด</p>
                    <h3 id="dash-total-trips" class="text-3xl font-bold text-gray-800 mt-1">-</h3>
                </div>
                <div class="w-12 h-12 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 text-xl">
                    <i class="fa-solid fa-suitcase-rolling"></i>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-lg border-l-4 border-blue-500 flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm font-medium">งบประมาณรวม</p>
                    <h3 id="dash-total-budget" class="text-3xl font-bold text-gray-800 mt-1">-</h3>
                </div>
                <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 text-xl">
                    <i class="fa-solid fa-baht-sign"></i>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-lg border-l-4 border-orange-500 flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm font-medium">เดินทางรวม (วัน)</p>
                    <h3 id="dash-total-days" class="text-3xl font-bold text-gray-800 mt-1">-</h3>
                </div>
                <div class="w-12 h-12 rounded-full bg-orange-100 flex items-center justify-center text-orange-600 text-xl">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
            </div>
        </div>

        <!-- Recent Trips Table -->
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
            <div class="bg-gray-50 border-b border-gray-200 p-6 flex justify-between items-center">
                <h2 class="text-xl font-semibold text-gray-800">ประวัติการเดินทางล่าสุด</h2>
                <button onclick="loadDashboardData()" class="text-sm text-primary hover:text-emerald-700 flex items-center gap-1 transition-colors">
                    <i class="fa-solid fa-rotate-right"></i> รีเฟรชข้อมูล
                </button>
            </div>
            <div class="p-6 overflow-x-auto">
                <div id="dashboard-loader" class="flex flex-col items-center justify-center py-10 text-gray-500">
                    <span class="loader border-t-primary w-8 h-8 mb-4"></span>
                    <p>กำลังโหลดข้อมูล...</p>
                </div>
                <table id="dashboard-table" class="w-full hidden text-left border-collapse min-w-[600px]">
                    <thead>
